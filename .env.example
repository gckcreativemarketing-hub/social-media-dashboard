# ──────────────────────────────────────────────────────────────────────
#  TEMPLATE — copy this file to ".env" and fill in the real values.
#  cp .env.example .env   (then paste your keys)
#
#  The real .env is gitignored (never committed) and CANNOT be pulled from
#  Vercel (all vars are "Sensitive"). On a new device you must fill these in
#  manually — easiest: AirDrop your working .env between Macs.
# ──────────────────────────────────────────────────────────────────────

# ── Instagram (Overview / Performance / Content tabs) ──
# Windsor.ai connector API key
WINDSOR_API_KEY=

# ── Google Sheets (Leads / Sales / Finance tabs) ──
# Service account JSON as a SINGLE line. From Google Cloud Console →
# IAM → Service Accounts → Keys (the same one wired in Vercel).
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=1fOgS0U0xl3TwOymgvevGMRBjFlSex-0usSxElMWecu4

# ── Market Radar — Twitter Pulse (Content tab) ──
# twitterapi.io dashboard → API key
TWITTERAPI_IO_KEY=
# console.anthropic.com → API Keys (curation engine)
ANTHROPIC_API_KEY=
# Optional: curation model (default claude-opus-4-8). Use Haiku to save cost.
CURATION_MODEL=claude-haiku-4-5
# Upstash Redis → upstash.com → your DB → "REST API" section
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Any random string — only used to auth the daily cron job
CRON_SECRET=

# ── App config (non-secret, safe defaults) ──
PORT=3000
BASE_PATH=/dashboard-sosmed
NODE_ENV=development
